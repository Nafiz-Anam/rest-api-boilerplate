#!/usr/bin/env sh
. "$(dirname -- "$0")/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged to check only staged files
npx lint-staged

# Temporarily skip TypeScript type checking
echo "📝 Skipping TypeScript type check (temporarily disabled)"

# Run tests if they exist
if [ -f "package.json" ] && grep -q '"test"' package.json; then
  echo "🧪 Skipping tests (temporarily disabled)"
  # npm test
fi

# Check for security issues
echo "🔒 Skipping security audit (temporarily disabled)"
# npm audit --audit-level moderate

echo "✅ Pre-commit checks completed!"
